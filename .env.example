# ─────────────────────────────────────────────────────────────────
# Relay — environment variables
# Copy this file to .env (or export inline) and fill in values.
# Never commit the resulting .env file. (.env is gitignored.)
# ─────────────────────────────────────────────────────────────────

# Encryption master key for tenant provider credentials.
# Generate with: pnpm db:keygen
# 32 bytes, hex or base64.
RELAY_MASTER_KEY=

# (Optional) Previous master key during a rotation window.
# Set this BEFORE flipping RELAY_MASTER_KEY to a new value so old rows can
# still be decrypted. Then run `pnpm db:rotate-master-key` to re-encrypt
# every row with the new key. Unset this once rotation completes.
RELAY_MASTER_KEY_PREVIOUS=

# Shared secret between control-plane and runtime for the /internal callback.
# Generate any random ~32-byte string. Optional in dev (warning shown).
RELAY_INTERNAL_SECRET=

# Tenant API key the SDK and dashboard use to talk to the control plane.
# Mint with: pnpm db:bootstrap   (prints relay_live_…)
RELAY_API_KEY=

# Postgres connection (admin / owner role). Used by migrations, signup,
# and the runtime callback. Bypasses Row-Level Security as the owner.
DATABASE_URL=postgres://relay:relay@localhost:5434/relay

# (Recommended in prod) Postgres connection as the non-owner `relay_app`
# role. The control plane uses this for authenticated, tenant-scoped
# queries so that RLS policies actually enforce — a SQL bug that drops the
# tenant filter cannot leak rows because the DB itself denies them.
#
# In Supabase, create a separate role and grant the same privileges as
# migration 004 does locally.  If unset, falls back to DATABASE_URL with a
# warning at boot (fine for dev, not safe for prod).
DATABASE_URL_APP=postgres://relay_app:relay_app@localhost:5434/relay

# Service URLs (defaults shown). Override in production.
RUNTIME_URL=http://localhost:4100
CONTROL_PLANE_URL=http://localhost:4000
PORT=4000

# Used ONLY by `pnpm db:bootstrap` to seed initial provider credentials.
# After bootstrap, credentials live encrypted in Postgres — these are not
# read by any running service.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENAI_BASE_URL=

# Tool result long-poll timeout (ms). Default 30000.
RELAY_TOOL_RESULT_TIMEOUT_MS=30000

# Custom-tool broker backend.
# Unset → in-memory map (fine for a single control-plane instance).
# Set   → NATS JetStream KV (required to run >1 control-plane replica;
#          docker-compose ships a local NATS at nats://localhost:4222).
NATS_URL=

# Rate-limit backend. Unset → per-replica in-memory limits. Set to enforce
# the limits fleet-wide across all control-plane replicas. Local default:
# redis://localhost:6379 (from docker-compose).
REDIS_URL=

# Event store mirror. Unset → events live only in Postgres. Set to enable
# double-write of run_events into ClickHouse. Format:
#   http(s)://user:password@host:8123/database
# Local default (docker-compose): http://relay:relay@localhost:8123/relay
CLICKHOUSE_URL=

# When ClickHouse is enabled and verified, flip reads:
#   READ_EVENTS_FROM=clickhouse   → dashboard/exports query ClickHouse
# Otherwise reads continue to come from Postgres.
READ_EVENTS_FROM=

# Bootstrap target tenant name. Default "default".
RELAY_TENANT_NAME=default
